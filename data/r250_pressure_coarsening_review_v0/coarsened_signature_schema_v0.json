    "coarsened_signature_hash",
    "coarsening_fields_used",
    "coarsening_payload",
    "coarsening_loss_fields",
    "parent_pressure_class",
    "pressure_subtype",
    "halt_reason",
    "move_kind",
    "evidence_field",
    "normalized_payload_family",
    "work_item_id",
    "slot_id",
    "source_receipt_ref",
